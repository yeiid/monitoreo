---
import DashboardLayout from "../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Cables & Rutas - FTTH Mapper">
    <div class="data-table-container animate-in">
        <div
            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;"
        >
            <div>
                <h1
                    style="font-size: 1.8rem; font-weight: 800; margin-bottom: 4px;"
                >
                    Cables y Rutas de Fibra
                </h1>
                <p style="color: var(--text-muted); font-size: 0.9rem;">
                    Administra el tendido de cables, capacidades y la generación
                    de hilos según la norma TIA-598.
                </p>
            </div>
            <div style="display: flex; gap: 12px;">
                <a href="/" class="btn btn-glass" style="text-decoration: none;"
                    >← Volver al Mapa</a
                >
                <button class="btn btn-primary">+ Nuevo Cable</button>
            </div>
        </div>

        <div
            class="glass-panel"
            style="padding: 20px 24px; margin-bottom: 24px; background: rgba(139, 92, 246, 0.03);"
        >
            <h3
                style="margin-bottom: 16px; font-size: 0.85rem; color: var(--text-primary); text-transform: uppercase; letter-spacing: 0.05em;"
            >
                Código de Colores TIA-598
            </h3>
            <div
                class="color-grid"
                id="color-grid"
                style="display: flex; flex-wrap: wrap; gap: 8px;"
            >
            </div>
        </div>

        <div class="glass-panel" style="padding: 4px;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Nombre del Cable</th>
                        <th>Tipo</th>
                        <th>Capacidad</th>
                        <th>Hilos</th>
                        <th>Descripción</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody id="routes-tbody">
                    <tr>
                        <td
                            colspan="6"
                            style="text-align:center; padding: 60px; color: var(--text-muted);"
                        >
                            <div class="animate-pulse">
                                Cargando rutas de fibra...
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</DashboardLayout>

<script>
    import { API_BASE } from "../components/map/types";
    import { TIA_COLORS } from "../constants/network";

    const colorGrid = document.getElementById("color-grid")!;
    if (colorGrid) {
        colorGrid.innerHTML = TIA_COLORS.map(
            (c, i) => `
            <div style="display: flex; align-items: center; gap: 8px; padding: 6px 10px; background: rgba(255,255,255,0.03); border-radius: 8px; border: 1px solid var(--border);">
                <div style="width: 12px; height: 12px; border-radius: 3px; background: ${
                    c.hex
                }; ${
                c.name === "Blanco" ? "border: 1px solid #444" : ""
            }"></div>
                <span style="font-size: 0.72rem; font-weight: 700; color: var(--text-muted); min-width: 14px;">${
                    i + 1
                }</span>
                <span style="font-size: 0.75rem; color: var(--text-secondary);">${
                    c.name
                }</span>
            </div>
        `
        ).join("");
    }

    async function loadRoutes() {
        try {
            const res = await fetch(`${API_BASE}/routes`);
            if (!res.ok) throw new Error("API error");
            const routes = await res.json();
            renderRoutes(routes);
        } catch {
            const tbody = document.getElementById("routes-tbody");
            if (tbody)
                tbody.innerHTML =
                    '<tr><td colspan="6" style="text-align:center;padding:40px;color:var(--error);">Error conectando con la API.</td></tr>';
        }
    }

    function renderRoutes(routes: any[]) {
        const tbody = document.getElementById("routes-tbody")!;
        if (routes.length === 0) {
            tbody.innerHTML =
                '<tr><td colspan="6" style="text-align:center;padding:40px;color:var(--text-muted);">No hay cables registrados.</td></tr>';
            return;
        }

        tbody.innerHTML = routes
            .map(
                (r: any) => `
            <tr class="animate-in">
                <td><strong style="color:white;">${r.name}</strong></td>
                <td>
                    <span class="badge" style="
                        background: ${
                            r.route_type === "TRONCAL"
                                ? "rgba(168, 85, 247, 0.1)"
                                : r.route_type === "DISTRIBUCION"
                                ? "rgba(59, 130, 246, 0.1)"
                                : "rgba(16, 185, 129, 0.1)"
                        };
                        color: ${
                            r.route_type === "TRONCAL"
                                ? "#A855F7"
                                : r.route_type === "DISTRIBUCION"
                                ? "#3B82F6"
                                : "#10B981"
                        };
                    ">
                        ${r.route_type || "TRONCAL"}
                    </span>
                </td>
                <td><span class="badge" style="background:rgba(255,255,255,0.05);color:var(--text-secondary);">${
                    r.capacity
                } hilos</span></td>
                <td>
                    <button class="btn btn-glass" style="font-size:0.75rem;padding:6px 12px;" onclick="generateStrands('${
                        r.id
                    }')">
                        Generar Hilos
                    </button>
                </td>
                <td style="font-size:0.85rem;color:var(--text-muted);">${
                    r.description || "—"
                }</td>
                <td>
                     <div style="display: flex; gap: 8px;">
                         <button class="btn btn-glass" style="padding: 6px 12px; font-size: 0.78rem;">Ver</button>
                        <button class="btn btn-glass" style="padding: 6px 12px; font-size: 0.78rem; color: var(--error);" onclick="deleteRoute('${
                            r.id
                        }')">Eliminar</button>
                    </div>
                </td>
            </tr>
        `
            )
            .join("");
    }

    (window as any).generateStrands = async function (routeId: string) {
        try {
            const res = await fetch(`${API_BASE}/strands/generate`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ route_id: routeId }),
            });
            if (res.ok) {
                const strands = await res.json();
                alert(
                    `Se generaron ${strands.length} hilos con colores TIA-598.`
                );
            }
        } catch (e) {
            alert("Error generando hilos.");
        }
    };

    (window as any).deleteRoute = async function (id: string) {
        if (!confirm("¿Eliminar este cable?")) return;
        try {
            await fetch(`${API_BASE}/routes/${id}`, { method: "DELETE" });
        } catch {}
        loadRoutes();
    };

    loadRoutes();
</script>
