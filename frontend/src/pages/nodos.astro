---
import DashboardLayout from "../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Nodos de Red - FTTH Mapper">
    <div class="data-table-container animate-in">
        <div
            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;"
        >
            <div>
                <h1
                    style="font-size: 1.8rem; font-weight: 800; margin-bottom: 4px;"
                >
                    Gestión de Nodos
                </h1>
                <p style="color: var(--text-muted); font-size: 0.9rem;">
                    Visualiza y administra todos los puntos físicos de tu
                    infraestructura.
                </p>
            </div>
            <div style="display: flex; gap: 12px;">
                <a href="/" class="btn btn-glass" style="text-decoration: none;"
                    >← Volver al Mapa</a
                >
                <button class="btn btn-primary">+ Nuevo Nodo</button>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card glass-panel">
                <div
                    class="stat-icon"
                    style="background: rgba(244, 63, 94, 0.1); color: var(--olt-color);"
                >
                    📡
                </div>
                <div class="stat-info">
                    <span class="label">Total OLTs</span>
                    <span class="value" id="count-olt">-</span>
                </div>
            </div>
            <div class="stat-card glass-panel">
                <div
                    class="stat-icon"
                    style="background: rgba(251, 191, 36, 0.1); color: var(--mufla-color);"
                >
                    🔶
                </div>
                <div class="stat-info">
                    <span class="label">Muflas</span>
                    <span class="value" id="count-mufla">-</span>
                </div>
            </div>
            <div class="stat-card glass-panel">
                <div
                    class="stat-icon"
                    style="background: rgba(34, 211, 238, 0.1); color: var(--nap-color);"
                >
                    📦
                </div>
                <div class="stat-info">
                    <span class="label">Cajas NAP</span>
                    <span class="value" id="count-nap">-</span>
                </div>
            </div>
            <div class="stat-card glass-panel">
                <div
                    class="stat-icon"
                    style="background: rgba(52, 211, 153, 0.1); color: var(--client-color);"
                >
                    🏠
                </div>
                <div class="stat-info">
                    <span class="label">Clientes ONU</span>
                    <span class="value" id="count-client">-</span>
                </div>
            </div>
        </div>

        <div class="glass-panel" style="padding: 4px;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Tipo</th>
                        <th>Ubicación</th>
                        <th>Potencia (dBm)</th>
                        <th>Descripción</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody id="nodes-tbody">
                    <tr>
                        <td
                            colspan="6"
                            style="text-align:center; padding: 60px; color: var(--text-muted);"
                        >
                            <div class="animate-pulse">
                                Cargando nodos de red...
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</DashboardLayout>

<script>
    import { API_BASE } from "../components/map/types";
    const NODE_BADGES: Record<string, string> = {
        OLT: "olt",
        MUFLA: "mufla",
        CAJA_NAP: "nap",
        CLIENTE_ONU: "client",
    };
    const NODE_LABELS: Record<string, string> = {
        OLT: "OLT",
        MUFLA: "Mufla",
        CAJA_NAP: "Caja NAP",
        CLIENTE_ONU: "Cliente ONU",
    };

    async function loadNodes() {
        try {
            // Initial load from cache for instant feel
            const cachedNodes = localStorage.getItem("ftth_nodes");
            if (cachedNodes) {
                renderNodes(JSON.parse(cachedNodes));
            }

            console.log(`[Nodes] Fetching from ${API_BASE}/nodes...`);
            const res = await fetch(`${API_BASE}/nodes`);
            if (!res.ok) throw new Error("API error");
            const nodes = await res.json();

            // Save to cache
            localStorage.setItem("ftth_nodes", JSON.stringify(nodes));
            renderNodes(nodes);
        } catch (e) {
            console.error(e);
            // If API fails, try to use cache if we haven't already
            if (!localStorage.getItem("ftth_nodes")) {
                document.getElementById("nodes-tbody")!.innerHTML =
                    '<tr><td colspan="5" style="text-align:center;padding:40px;color:var(--error);">Error conectando con la API y no hay datos locales.</td></tr>';
            }
        }
    }

    function renderNodes(nodes: any[]) {
        // Update counts
        const counts: Record<string, number> = {
            OLT: 0,
            MUFLA: 0,
            CAJA_NAP: 0,
            CLIENTE_ONU: 0,
        };
        nodes.forEach((n: any) => {
            if (counts[n.node_type] !== undefined) counts[n.node_type]++;
        });
        document.getElementById("count-olt")!.textContent = String(counts.OLT);
        document.getElementById("count-mufla")!.textContent = String(
            counts.MUFLA
        );
        document.getElementById("count-nap")!.textContent = String(
            counts.CAJA_NAP
        );
        document.getElementById("count-client")!.textContent = String(
            counts.CLIENTE_ONU
        );

        const tbody = document.getElementById("nodes-tbody")!;
        if (nodes.length === 0) {
            tbody.innerHTML =
                '<tr><td colspan="6" style="text-align:center;padding:40px;color:var(--text-muted);">No hay nodos registrados.</td></tr>';
            return;
        }

        const BADGE_MAP: Record<string, string> = {
            OLT: "badge-olt",
            MUFLA: "badge-mufla",
            CAJA_NAP: "badge-nap",
            CLIENTE_ONU: "badge-client",
        };

        tbody.innerHTML = nodes
            .map(
                (n: any) => `
            <tr class="animate-in">
                <td><strong style="color:white;">${n.name}</strong></td>
                <td>
                    <span class="badge ${BADGE_MAP[n.node_type] || 'badge-olt'}">
                        ${NODE_LABELS[n.node_type] || n.node_type}
                    </span>
                </td>
                <td style="font-size:0.82rem;font-family:monospace;">
                    ${parseFloat(n.location?.lat).toFixed(5)}, ${parseFloat(n.location?.lng).toFixed(5)}
                </td>
                <td style="font-weight:bold;color:${n.optical_power_dbm < -25 ? 'var(--error)' : 'var(--success)'};">
                    ${n.optical_power_dbm != null ? n.optical_power_dbm + ' dBm' : '—'}
                </td>
                <td style="font-size:0.85rem;color:var(--text-muted);">${
                    n.description || "—"
                }</td>
                <td>
                    <div style="display:flex;gap:8px;">
                        <button class="secondary-btn" style="font-size:0.72rem;padding:4px 10px;" onclick="centerOnNode('${n.id}')">Ubicar</button>
                        <button class="danger-btn" style="font-size:0.72rem;padding:4px 10px;" onclick="deleteNode('${n.id}')">Eliminar</button>
                    </div>
                </td>
            </tr>
        `
            )
            .join("");
    }

    (window as any).deleteNode = async function (id: string) {
        if (!confirm("¿Eliminar este nodo?")) return;
        try {
            await fetch(`${API_BASE}/nodes/${id}`, { method: "DELETE" });
        } catch {}
        loadNodes();
    };

    loadNodes();
</script>

<style>
    .dashboard-container {
        display: flex;
        height: 100vh;
        width: 100vw;
    }

    .main-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 16px 24px 16px 0;
        overflow: hidden;
    }

    .content-scroll {
        flex: 1;
        overflow-y: auto;
        padding-right: 8px;
    }

    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .content-header h1 {
        font-size: 1.6rem;
        color: white;
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 14px;
        margin-bottom: 24px;
    }

    .mini-stat {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 18px 20px;
    }

    .mini-stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
    }

    .mini-stat-label {
        display: block;
        font-size: 0.72rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 500;
    }

    .mini-stat-value {
        display: block;
        font-size: 1.4rem;
        font-weight: 800;
        color: white;
    }

    .table-container {
        padding: 4px;
        overflow-x: auto;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

    .data-table th {
        color: var(--text-muted);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 14px 18px;
        border-bottom: 1px solid var(--border-color);
        font-weight: 600;
    }

    .data-table td {
        padding: 14px 18px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        color: var(--text-main);
        font-size: 0.88rem;
    }

    .data-table tbody tr:hover {
        background: rgba(255, 255, 255, 0.02);
    }
</style>
