---
import Layout from "../layouts/Layout.astro";
import AppShell from "../components/AppShell";
---

<Layout title="FTTH Mapper - Diseño de Planta Externa">
	<AppShell client:only="react" />
</Layout>

<style is:global>
	.dashboard-container {
		display: flex;
		height: 100vh;
		width: 100vw;
		background-color: var(--bg-main);
	}

	.main-content {
		flex: 1;
		display: flex;
		flex-direction: column;
		padding: 16px;
		overflow: hidden;
	}

	@media (min-width: 1024px) {
		.main-content {
			padding: 16px 16px 16px 0;
		}
	}

	.map-full-container {
		flex: 1;
		position: relative;
		border-radius: 12px;
		overflow: hidden;
		border: 1px solid var(--border);
	}

	#map-app {
		width: 100%;
		height: 100%;
	}
</style>
