---
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar";
import Header from "../components/Header";
import MapApp from "../components/MapApp";
---

<Layout title="FTTH Mapper - Diseño de Planta Externa">
	<main class="dashboard-container">
		<Sidebar client:load />

		<div class="main-content">
			<Header client:load />

			<div class="map-full-container">
				<MapApp client:only="react" />
			</div>
		</div>
	</main>
</Layout>

<style>
	.dashboard-container {
		display: flex;
		height: 100vh;
		width: 100vw;
		background-color: var(--bg-color);
	}

	.main-content {
		flex: 1;
		display: flex;
		flex-direction: column;
		padding: 16px;
		overflow: hidden;
	}

	@media (min-width: 1024px) {
		.main-content {
			padding: 16px 16px 16px 0;
		}
	}

	.map-full-container {
		flex: 1;
		position: relative;
		border-radius: 12px;
		overflow: hidden;
		border: 1px solid var(--border-color);
	}

	#map-app {
		width: 100%;
		height: 100%;
	}
</style>
