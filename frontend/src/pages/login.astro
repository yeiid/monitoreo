---
import Layout from "../layouts/Layout.astro";
import LoginApp from "../components/auth/LoginApp.tsx";
---

<Layout title="FTTH Mapper - Iniciar Sesión">
    <script>
        // Check session before rendering
        if (localStorage.getItem("ftth_token")) {
            window.location.href = "/";
        }
    </script>
    <LoginApp client:only="react" />
</Layout>

<style is:global>
    /* ── Login Page Styles ── */
    .login-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        width: 100%;
        background: linear-gradient(
            135deg,
            #0a0e1a 0%,
            #111827 40%,
            #0f172a 100%
        );
        overflow: hidden;
        font-family:
            "Inter",
            "Segoe UI",
            -apple-system,
            sans-serif;
    }

    .login-card {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 420px;
        padding: 40px;
        background: rgba(17, 24, 39, 0.75);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        box-shadow:
            0 0 0 1px rgba(255, 255, 255, 0.03),
            0 20px 60px rgba(0, 0, 0, 0.5),
            0 0 120px rgba(99, 102, 241, 0.08);
    }

    .login-header {
        text-align: center;
        margin-bottom: 32px;
    }

    .login-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        margin-bottom: 8px;
    }

    .logo-icon {
        font-size: 2rem;
        filter: drop-shadow(0 0 12px rgba(99, 102, 241, 0.4));
    }

    .login-logo h1 {
        font-size: 1.75rem;
        font-weight: 700;
        background: linear-gradient(135deg, #818cf8, #6366f1, #a78bfa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
    }

    .login-subtitle {
        color: rgba(148, 163, 184, 0.8);
        font-size: 0.875rem;
        margin: 0;
    }

    /* Form */
    .login-form {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .form-group label {
        display: block;
        color: rgba(203, 213, 225, 0.9);
        font-size: 0.8rem;
        font-weight: 500;
        margin-bottom: 6px;
        letter-spacing: 0.02em;
    }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-icon {
        position: absolute;
        left: 14px;
        font-size: 0.9rem;
        pointer-events: none;
        opacity: 0.6;
    }

    .input-wrapper input {
        width: 100%;
        padding: 12px 14px 12px 42px;
        background: rgba(15, 23, 42, 0.6);
        border: 1px solid rgba(99, 102, 241, 0.15);
        border-radius: 12px;
        color: #e2e8f0;
        font-size: 0.9rem;
        outline: none;
        transition: all 0.3s ease;
    }

    .input-wrapper input:focus {
        border-color: rgba(99, 102, 241, 0.5);
        box-shadow:
            0 0 0 3px rgba(99, 102, 241, 0.1),
            0 0 20px rgba(99, 102, 241, 0.1);
    }

    .input-wrapper input::placeholder {
        color: rgba(148, 163, 184, 0.4);
    }

    .toggle-password {
        position: absolute;
        right: 12px;
        background: none;
        border: none;
        cursor: pointer;
        font-size: 0.9rem;
        padding: 4px;
        opacity: 0.6;
        transition: opacity 0.2s;
    }

    .toggle-password:hover {
        opacity: 1;
    }

    /* Login Button */
    .login-btn {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border: none;
        border-radius: 12px;
        color: white;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        margin-top: 4px;
    }

    .login-btn:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 8px 25px rgba(99, 102, 241, 0.35);
    }

    .login-btn:active:not(:disabled) {
        transform: translateY(0);
    }

    .login-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    /* Spinner */
    .login-spinner {
        display: inline-block;
        width: 20px;
        height: 20px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        border-top-color: white;
        animation: spin 0.7s linear infinite;
    }

    @keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* Error */
    .login-error {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 16px;
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: 10px;
        color: #fca5a5;
        font-size: 0.85rem;
        animation: shakeX 0.4s ease;
    }

    @keyframes shakeX {
        0%,
        100% {
            transform: translateX(0);
        }
        25% {
            transform: translateX(-6px);
        }
        75% {
            transform: translateX(6px);
        }
    }

    /* Footer */
    .login-footer {
        text-align: center;
        margin-top: 28px;
        padding-top: 20px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .login-footer p {
        color: rgba(100, 116, 139, 0.6);
        font-size: 0.72rem;
        margin: 0;
    }

    /* Background Decorations */
    .login-bg-decoration {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
    }

    .bg-circle {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.15;
    }

    .bg-circle-1 {
        width: 500px;
        height: 500px;
        background: #6366f1;
        top: -200px;
        right: -100px;
        animation: float1 15s ease-in-out infinite;
    }

    .bg-circle-2 {
        width: 400px;
        height: 400px;
        background: #8b5cf6;
        bottom: -150px;
        left: -100px;
        animation: float2 18s ease-in-out infinite;
    }

    .bg-circle-3 {
        width: 300px;
        height: 300px;
        background: #06b6d4;
        top: 40%;
        left: 50%;
        animation: float3 20s ease-in-out infinite;
    }

    @keyframes float1 {
        0%,
        100% {
            transform: translate(0, 0) scale(1);
        }
        50% {
            transform: translate(-40px, 30px) scale(1.1);
        }
    }

    @keyframes float2 {
        0%,
        100% {
            transform: translate(0, 0) scale(1);
        }
        50% {
            transform: translate(30px, -40px) scale(1.05);
        }
    }

    @keyframes float3 {
        0%,
        100% {
            transform: translate(0, 0) scale(1);
        }
        50% {
            transform: translate(-20px, 20px) scale(0.95);
        }
    }

    /* Responsive */
    @media (max-width: 480px) {
        .login-card {
            margin: 16px;
            padding: 28px 24px;
        }
    }
</style>
