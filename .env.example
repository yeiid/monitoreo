# Configuración de Base de Datos (PostGIS)
POSTGRES_USER=monitoreo
POSTGRES_PASSWORD=monitoreo123
POSTGRES_DB=monitoreodb

# Configuración de Backend (FastAPI)
# En Dokploy, DATABASE_URL se construye dinámicamente o se define así:
DATABASE_URL=postgresql+asyncpg://monitoreo:monitoreo123@db:5432/monitoreodb
CORS_ORIGINS=*

# Configuración de Frontend (Astro)
# Estas variables se usan durante la construcción del frontend
PUBLIC_API_URL=https://api.tu-dominio.com/api/v1
PUBLIC_MAP_TILE_URL=https://mapa.tu-dominio.com/styles/basic/style.json

# Servidor de Mapas (TileServer GL)
# Asegúrate de que los archivos estén en /var/lib/monitoreo/maps en tu VPS
MAP_SERVER_PORT=8080
