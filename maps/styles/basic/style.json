{
    "version": 8,
    "name": "Monitoreo Dark",
    "metadata": {
        "maputnik:renderer": "mlgljs"
    },
    "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
    "sources": {
        "openmaptiles": {
            "type": "vector",
            "url": "mbtiles://{colombia}"
        }
    },
    "layers": [
        {
            "id": "background",
            "type": "background",
            "paint": {
                "background-color": "#121218"
            }
        },
        {
            "id": "landuse-park",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landuse",
            "filter": [
                "in",
                "class",
                "park",
                "cemetery",
                "grass"
            ],
            "paint": {
                "fill-color": "#1a2418",
                "fill-opacity": 0.6
            }
        },
        {
            "id": "landuse-residential",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landuse",
            "filter": [
                "==",
                "class",
                "residential"
            ],
            "paint": {
                "fill-color": "#16161e",
                "fill-opacity": 0.5
            }
        },
        {
            "id": "landuse-commercial",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "landuse",
            "filter": [
                "in",
                "class",
                "commercial",
                "industrial",
                "retail"
            ],
            "paint": {
                "fill-color": "#1a1820",
                "fill-opacity": 0.4
            }
        },
        {
            "id": "water",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "water",
            "paint": {
                "fill-color": "#1a2535",
                "fill-opacity": 0.8
            }
        },
        {
            "id": "building",
            "type": "fill",
            "source": "openmaptiles",
            "source-layer": "building",
            "minzoom": 13,
            "paint": {
                "fill-color": "#1e1e28",
                "fill-outline-color": "#2a2a38",
                "fill-opacity": {
                    "stops": [
                        [
                            13,
                            0.3
                        ],
                        [
                            16,
                            0.7
                        ]
                    ]
                }
            }
        },
        {
            "id": "road-path",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": [
                "in",
                "class",
                "path",
                "track"
            ],
            "minzoom": 14,
            "paint": {
                "line-color": "#2a2a35",
                "line-width": {
                    "stops": [
                        [
                            14,
                            0.5
                        ],
                        [
                            18,
                            1.5
                        ]
                    ]
                },
                "line-dasharray": [
                    2,
                    2
                ]
            }
        },
        {
            "id": "road-minor",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": [
                "in",
                "class",
                "minor",
                "service"
            ],
            "minzoom": 12,
            "paint": {
                "line-color": "#2d2d3a",
                "line-width": {
                    "stops": [
                        [
                            12,
                            0.4
                        ],
                        [
                            15,
                            1.5
                        ],
                        [
                            18,
                            4
                        ]
                    ]
                }
            }
        },
        {
            "id": "road-secondary",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": [
                "==",
                "class",
                "secondary"
            ],
            "paint": {
                "line-color": "#383848",
                "line-width": {
                    "stops": [
                        [
                            8,
                            0.5
                        ],
                        [
                            13,
                            2
                        ],
                        [
                            18,
                            6
                        ]
                    ]
                }
            }
        },
        {
            "id": "road-primary",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": [
                "==",
                "class",
                "primary"
            ],
            "paint": {
                "line-color": "#424258",
                "line-width": {
                    "stops": [
                        [
                            7,
                            0.5
                        ],
                        [
                            12,
                            2
                        ],
                        [
                            18,
                            8
                        ]
                    ]
                }
            }
        },
        {
            "id": "road-trunk",
            "type": "line",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "filter": [
                "in",
                "class",
                "trunk",
                "motorway"
            ],
            "paint": {
                "line-color": "#4a4a65",
                "line-width": {
                    "stops": [
                        [
                            5,
                            0.5
                        ],
                        [
                            10,
                            2
                        ],
                        [
                            16,
                            8
                        ],
                        [
                            20,
                            14
                        ]
                    ]
                }
            }
        },
        {
            "id": "road-label",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "transportation",
            "minzoom": 15,
            "layout": {
                "text-field": "{name}",
                "text-font": [
                    "Noto Sans Regular"
                ],
                "text-size": 11,
                "symbol-placement": "line"
            },
            "paint": {
                "text-color": "#8888aa",
                "text-halo-color": "#121218",
                "text-halo-width": 1.5
            }
        },
        {
            "id": "place-village",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "place",
            "filter": [
                "==",
                "class",
                "village"
            ],
            "minzoom": 12,
            "layout": {
                "text-field": "{name}",
                "text-font": [
                    "Noto Sans Regular"
                ],
                "text-size": 11,
                "text-max-width": 8,
                "text-anchor": "center"
            },
            "paint": {
                "text-color": "#8888aa",
                "text-halo-color": "#121218",
                "text-halo-width": 1.5
            }
        },
        {
            "id": "place-town",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "place",
            "filter": [
                "==",
                "class",
                "town"
            ],
            "minzoom": 9,
            "layout": {
                "text-field": "{name}",
                "text-font": [
                    "Noto Sans Regular"
                ],
                "text-size": {
                    "stops": [
                        [
                            9,
                            11
                        ],
                        [
                            14,
                            15
                        ]
                    ]
                },
                "text-max-width": 8,
                "text-anchor": "center"
            },
            "paint": {
                "text-color": "#9999bb",
                "text-halo-color": "#121218",
                "text-halo-width": 2
            }
        },
        {
            "id": "place-city",
            "type": "symbol",
            "source": "openmaptiles",
            "source-layer": "place",
            "filter": [
                "==",
                "class",
                "city"
            ],
            "minzoom": 6,
            "layout": {
                "text-field": "{name}",
                "text-font": [
                    "Noto Sans Bold"
                ],
                "text-size": {
                    "stops": [
                        [
                            6,
                            12
                        ],
                        [
                            10,
                            18
                        ],
                        [
                            14,
                            22
                        ]
                    ]
                },
                "text-max-width": 10,
                "text-anchor": "center",
                "text-allow-overlap": false
            },
            "paint": {
                "text-color": "#bbbbdd",
                "text-halo-color": "#121218",
                "text-halo-width": 2
            }
        }
    ],
    "id": "monitoreo-dark"
}